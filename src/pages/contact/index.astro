---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../utils/paths';
---
<Base
  title="Contact"
  description="Contact Inkwell Press — submissions, book orders, rights enquiries, and general correspondence. Based in Edinburgh, Scotland."
>

  <!-- Page Hero -->
  <section class="page-hero" aria-label="Contact">
    <div class="container">
      <span class="page-hero-eyebrow">Get in Touch</span>
      <h1 class="page-hero-title">Contact Us</h1>
      <p class="page-hero-desc">
        We're a small press and we read every letter. Please allow 5–7 working days for a reply.
      </p>
    </div>
  </section>

  <section class="section section--cream" aria-label="Contact information and form">
    <div class="container">
      <div class="contact-grid">

        <!-- Contact Information -->
        <div class="contact-info">
          <h2>Write to Inkwell</h2>
          <span class="gold-rule" aria-hidden="true"></span>

          <div class="contact-entry">
            <div class="contact-entry-label">Postal Address</div>
            <address class="contact-entry-value" style="font-style:normal;">
              Inkwell Press<br />
              14 Victoria Street<br />
              Edinburgh EH1 2HW<br />
              Scotland, United Kingdom
            </address>
          </div>

          <div class="contact-entry">
            <div class="contact-entry-label">Submissions</div>
            <div class="contact-entry-value">
              <a href="mailto:submissions@inkwellpress.co.uk">submissions@inkwellpress.co.uk</a><br />
              <span style="font-size:0.85rem;color:var(--color-muted);">Essays, translations, creative work, book proposals</span>
            </div>
          </div>

          <div class="contact-entry">
            <div class="contact-entry-label">Book Orders &amp; Trade</div>
            <div class="contact-entry-value">
              <a href="mailto:orders@inkwellpress.co.uk">orders@inkwellpress.co.uk</a><br />
              <span style="font-size:0.85rem;color:var(--color-muted);">Institutional and bulk orders, bookseller accounts</span>
            </div>
          </div>

          <div class="contact-entry">
            <div class="contact-entry-label">Rights &amp; Licensing</div>
            <div class="contact-entry-value">
              <a href="mailto:rights@inkwellpress.co.uk">rights@inkwellpress.co.uk</a><br />
              <span style="font-size:0.85rem;color:var(--color-muted);">Translation rights, audio, film, and licensing enquiries</span>
            </div>
          </div>

          <div class="contact-entry">
            <div class="contact-entry-label">General Enquiries</div>
            <div class="contact-entry-value">
              <a href="mailto:hello@inkwellpress.co.uk">hello@inkwellpress.co.uk</a><br />
              <span style="font-size:0.85rem;color:var(--color-muted);">Subscriptions, press, events, everything else</span>
            </div>
          </div>

          <div style="background:var(--color-warm-paper);border:1px solid var(--color-border);border-radius:var(--radius-md);padding:1.25rem 1.5rem;margin-top:1.5rem;">
            <p style="font-family:var(--font-ui);font-size:0.72rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.5rem;">Response Times</p>
            <ul style="list-style:disc;padding-left:1.25rem;font-size:0.875rem;color:var(--color-muted);line-height:1.8;">
              <li>General enquiries: 5–7 working days</li>
              <li>Journal submissions: 10–12 weeks</li>
              <li>Book proposals: 12–16 weeks</li>
              <li>Rights: 3–4 weeks</li>
            </ul>
          </div>
        </div>

        <!-- Write to Us -->
        <div class="contact-form">
          <h3>Write to Us</h3>
          <span class="gold-rule" aria-hidden="true"></span>
          <div style="background:var(--color-paper);border:1px solid var(--color-border);border-radius:8px;padding:2.5rem;margin-top:2rem;">
            <h3 style="color:var(--color-navy);font-size:1.3rem;margin-bottom:1rem;">Write to Us</h3>
            <p style="color:var(--color-muted);line-height:1.8;margin-bottom:1.5rem;">
              For editorial enquiries, submission queries, subscription information, or general correspondence, please email us directly.
            </p>
            <a href="mailto:editors@inkwelljournal.org" class="btn btn--primary">editors@inkwelljournal.org</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Map / Location callout -->
  <section class="section--sm section--paper">
    <div class="container">
      <div style="max-width:640px;margin:0 auto;text-align:center;">
        <p class="section-eyebrow">Visit Us</p>
        <h3 style="color:var(--color-navy);margin-bottom:0.5rem;">Edinburgh Office</h3>
        <span class="gold-rule gold-rule--center" aria-hidden="true"></span>
        <p style="color:var(--color-muted);font-size:0.9375rem;line-height:1.8;">
          Our office is located on Victoria Street in Edinburgh's Old Town — a short walk from
          Grassmarket and the Royal Mile. We do not operate a bookshop and are not generally
          open to walk-in visitors, but we are happy to receive visitors by appointment.
        </p>
        <p style="color:var(--color-muted);font-size:0.9375rem;margin-top:0.75rem;">
          14 Victoria Street, Edinburgh EH1 2HW
        </p>
      </div>
    </div>
  </section>

</Base>
