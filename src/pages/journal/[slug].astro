---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../utils/paths';

const { slug } = Astro.params;
---

<Base
  title="Journal Article"
  description="An essay from the Inkwell Journal."
>
  <section class="page-hero" aria-label="Article">
    <div class="container">
      <span class="page-hero-eyebrow">Inkwell Journal</span>
      <h1 class="page-hero-title">Article Placeholder</h1>
      <p class="page-hero-desc">
        This article is available in the full print and digital edition of the Inkwell Journal.
      </p>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container" style="max-width: 720px;">
      <div style="background:var(--color-paper);border:1px solid var(--color-border);border-radius:8px;padding:3rem;text-align:center;">
        <p style="font-size:3rem;margin-bottom:1rem;">📖</p>
        <h2 style="color:var(--color-navy);margin-bottom:1rem;">Full article coming soon</h2>
        <p style="color:var(--color-muted);line-height:1.8;margin-bottom:2rem;">
          The full text of this essay will be available here once the journal is published.
          Subscribers receive access to all articles in PDF format.
        </p>
        <a href={withBase('/journal/')} class="btn btn--outline btn--sm">← Back to Journal</a>
      </div>
    </div>
  </section>
</Base>
